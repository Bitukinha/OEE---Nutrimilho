# Copie para .env ou .env.local e preencha com os valores do Supabase.
# Supabase Dashboard: https://app.supabase.com > seu projeto > Settings > API

# Project URL (exatamente como no painel, sem @ no meio)
VITE_SUPABASE_URL=https://SEU_PROJETO_ID.supabase.co

# anon / public key (Project API keys)
VITE_SUPABASE_PUBLISHABLE_KEY=sua_chave_anon_public_aqui
