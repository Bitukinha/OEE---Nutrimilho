# Copie para .env e preencha com os valores do Supabase.
# Dashboard: https://supabase.com/dashboard > projeto > Settings > API

# Project URL (sem @ no meio)
VITE_SUPABASE_URL=https://SEU_PROJETO_ID.supabase.co

# Desenvolvimento local: proxy injeta a service role (não expõe no navegador)
VITE_SUPABASE_USE_PROXY=true
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# Produção/Vercel: anon key do MESMO projeto da URL acima
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui
VITE_SUPABASE_USE_PROXY=false
